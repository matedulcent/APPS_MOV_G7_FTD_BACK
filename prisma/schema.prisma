generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         String  @id @map("ID_Usuario")
  nombre     String?
  mail       String? @unique
  contrasena String?
  ordenes    Orden[] @relation("usuarioOrdenes")
}

model Sucursal {
  id         String  @id @map("ID_Sucursal")
  nombre     String?
  mail       String? @unique
  contrasena String?
  urlImagen  String?
  domicilio  String?
  ordenes    Orden[]

  // NUEVO: ofertas M:N
  envasesOfrecidos Envase[]
  saboresOfrecidos Sabor[]
}

model Orden {
  id              String    @id @map("ID_Pedido")
  fecha           DateTime?
  estadoTerminado Boolean   @default(false)
  usuarioId       String
  sucursalId      String

  usuario    Usuario           @relation("usuarioOrdenes", fields: [usuarioId], references: [id], onDelete: Cascade)
  sucursal   Sucursal          @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  contenidos ContenidoPedido[]
}

model Envase {
  id             String            @id @map("ID_Envase")
  tipoEnvase     String            @unique
  maxCantSabores Int
  categoria      String            @default("Especiales")
  contenidos     ContenidoPedido[]

  // backref M:N con sucursal
  sucursales Sucursal[]
}

model Sabor {
  id         String            @id @map("ID_SABOR")
  tipoSabor  String            @unique
  categoria  String            @default("Especiales")
  contenidos ContenidoPedido[]

  // backref M:N con sucursal
  sucursales Sucursal[]
}

// Listado de secciones/categorías gestionables desde el panel de vendedor.
// Son independientes de los items: permiten crear una sección vacía y
// borrarla, en vez de inferir la lista únicamente de lo que ya existe.
model CategoriaEnvase {
  id     String @id @default(uuid())
  nombre String @unique
}

model CategoriaSabor {
  id     String @id @default(uuid())
  nombre String @unique
}

model ContenidoPedido {
  id       Int    @id @default(autoincrement())
  ordenId  String
  envaseId String
  saborId  String
  // Distingue a qué envase físico del pedido pertenece este sabor (p. ej. dos
  // kilos en el mismo pedido con gustos distintos no deben mezclarse). Único
  // por (ordenId, grupo) en la práctica; sin FK propia, lo arma el back al crear la orden.
  grupo    Int    @default(0)

  orden  Orden  @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  envase Envase @relation(fields: [envaseId], references: [id], onDelete: Cascade)
  sabor  Sabor  @relation(fields: [saborId], references: [id], onDelete: Cascade)

  @@index([ordenId])
  @@index([envaseId])
  @@index([saborId])
}
